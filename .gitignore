# ==============================================================================
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# ==============================================================================
# Jupyter Notebooks
# ==============================================================================
.ipynb_checkpoints/
*.ipynb_checkpoints

# ==============================================================================
# Model Checkpoints & Weights (keep folders, ignore files)
# ==============================================================================
# Checkpoint directories - keep structure via .gitkeep
runs/
checkpoints/
outputs/
*.pt
*.pth
*.bin
*.safetensors
*.ckpt
*.h5
*.onnx

# Specific checkpoint patterns
step_*/
checkpoint-*/
adapter_model.bin
adapter_model.safetensors
pytorch_model.bin
model.safetensors

# ==============================================================================

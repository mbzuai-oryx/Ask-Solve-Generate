# ==============================================================================
logs/
*.log
*.out
*.err
wandb/
mlruns/
tensorboard/
events.out.tfevents.*
iter_log.jsonl
trainer_state.pt

# ==============================================================================
# Cache Files
# ==============================================================================
.cache/
cache/
*.cache
hub/
~/.cache/
transformers_cache/
huggingface/

# ==============================================================================
# Public-release boundary
# ==============================================================================
# Do not publish private data construction pipelines. The public repository should
# contain training, evaluation, and inference code; users provide their own image
# directory through DATA_DIR.
/data_pipeline/
/docs/
/BLIP3o/eval/lmms-eval/tools/
/BLIP3o/tests/
/scripts/download_*.py
/scripts/filter_dataset_images.py
/scripts/submit_*.sbatch
/vargpt_1_1/VARGPT-family-training/data_temp/
/vargpt_1_1/VARGPT-family-training/docker/
/vargpt_1_1/VARGPT-family-training/README_llamafactory.md
/vargpt_1_1/VARGPT-family-training/README_zh.md
